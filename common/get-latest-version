#!/usr/bin/env python3

import argparse
import json
import os
import sys
import urllib.request


def main():
    parser = argparse.ArgumentParser(
        description="Get the latest release version of a GitHub repo.",
        formatter_class=argparse.ArgumentDefaultsHelpFormatter,
    )
    parser.add_argument("repo", help="GitHub repo in owner/repo format")
    parser.add_argument(
        "--strip-prefix",
        default=None,
        help="Prefix to strip from the tag name",
    )
    parser.add_argument(
        "--github-host",
        default="api.github.com",
        help="GitHub API hostname",
    )
    parser.add_argument(
        "--token-var",
        default="GITHUB_TOKEN",
        help="GitHub token environment variable name",
    )
    args = parser.parse_args()

    repo = args.repo
    url = f"https://{args.github_host}/repos/{repo}/releases/latest"

    req = urllib.request.Request(url)
    token = os.environ.get(args.token_var)
    if token:
        req.add_header("Authorization", f"token {token}")

    try:
        with urllib.request.urlopen(req) as resp:
            data = json.loads(resp.read())
    except urllib.error.URLError as e:
        sys.exit(f"Error fetching latest version for {repo}: {e}")

    version = data["tag_name"]

    if args.strip_prefix:
        version = version.removeprefix(args.strip_prefix)

    print(version)


if __name__ == "__main__":
    main()
