#!/usr/bin/make -f

PKG_VERSION := $(or $(PKG_VERSION),$(error PKG_VERSION not set))
COPILOT_TARBALL := copilot-cli-$(PKG_VERSION).tar.gz
COPILOT_URL := https://github.com/github/copilot-cli/releases/download/v$(PKG_VERSION)/copilot-linux-x64.tar.gz

%:
	dh $@

override_dh_auto_build:
	curl -sL -o $(COPILOT_TARBALL) $(COPILOT_URL)
	rm -rf source
	mkdir -p source
	tar xzf $(COPILOT_TARBALL) -C source

override_dh_auto_install:
	install -D -m 755 source/copilot debian/copilot/usr/bin/copilot

override_dh_auto_clean:
	rm -rf $(COPILOT_TARBALL) source

override_dh_dwz:
	# Skip DWARF optimization for pre-built binaries

override_dh_strip:
	# Skip stripping pre-built binaries

override_dh_shlibdeps:
	# Skip shared library dependency detection for pre-built binary
