#!/usr/bin/make -f

PKG_VERSION := $(or $(PKG_VERSION),$(error PKG_VERSION not set))
TYPOS_TARBALL := typos-$(PKG_VERSION).tar.gz
TYPOS_URL := https://github.com/crate-ci/typos/releases/download/v$(PKG_VERSION)/typos-v$(PKG_VERSION)-x86_64-unknown-linux-musl.tar.gz

%:
	dh $@

override_dh_auto_build:
	curl -sL -o $(TYPOS_TARBALL) $(TYPOS_URL)
	rm -rf source
	mkdir -p source
	tar xzf $(TYPOS_TARBALL) -C source

override_dh_auto_install:
	install -D -m 755 source/typos debian/typos/usr/bin/typos

override_dh_auto_clean:
	rm -rf $(TYPOS_TARBALL) source

override_dh_strip:
	# Skip stripping pre-built binaries

override_dh_shlibdeps:
	# Skip shared library dependency detection for pre-built binary
